# CiteMind Web Frontend Environment Variables

# API URL for backend services
VITE_API_URL=http://localhost:3000

# Optional: Sentry DSN for error tracking
# VITE_SENTRY_DSN=

# Optional: PostHog key for analytics
# VITE_POSTHOG_KEY=

# Optional: Enable mock AI responses for offline development
VITE_MOCK_AI=true

# Optional: Public app URL (used for OAuth callbacks, sharing)
VITE_APP_URL=http://localhost:5173
