# CiteMind API Environment Variables
# Copy this file to .env and fill in your values

NODE_ENV=development
PORT=3000

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/citemind

# Redis connection string
REDIS_URL=redis://localhost:6379

# JWT configuration (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production-32chars
JWT_EXPIRES_IN=7d

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# AI provider (mock | openai)
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=gpt-4o

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS origin
CORS_ORIGIN=http://localhost:5173
